# Knowz Self-Hosted Environment Configuration
# Copy this file to .env and customize values.
# Usage: docker compose up -d

# ===== REQUIRED =====

# SQL Server SA password (minimum 8 chars, must include uppercase, lowercase, number/symbol)
SA_PASSWORD=Knowz_Dev_P@ssw0rd!

# JWT secret for authentication tokens (CHANGE IN PRODUCTION - minimum 32 characters)
JWT_SECRET=change-this-to-a-random-64-char-string-in-production-please!!

# SuperAdmin credentials (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ===== OPTIONAL: Azure AI Services =====
# Uncomment and set these to enable AI features (search, summarization, chat).
# Without these, the app runs with basic CRUD — no AI features.

# AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_AI_SEARCH_API_KEY=your-api-key

# ===== OPTIONAL: MCP Server =====
# The MCP (Model Context Protocol) server enables AI tools (Claude, etc.) to
# interact with your knowledge base. It proxies requests to the API.

# Host port for MCP server (default: 3001)
# MCP_PORT=3001

# Internal API URL (change only if using a custom network setup)
# MCP_API_URL=http://api:8080

# Whether the MCP server validates API keys on incoming requests (default: true)
# MCP_VALIDATE_API_KEY=true

# MCP backend mode (default: selfhosted — "proxy" is for Knowz platform only)
# MCP_BACKEND_MODE=selfhosted

# API endpoint used by MCP to validate API keys (default: /api/auth/me)
# MCP_API_KEY_VALIDATION_ENDPOINT=/api/v1/auth/me

# ===== OPTIONAL: Storage =====
# Default: local filesystem (files stored in Docker volume).
# Uncomment to use Azure Blob Storage instead.

# STORAGE_PROVIDER=AzureBlobStorage
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;...
# AZURE_STORAGE_CONTAINER=selfhosted-files

# ===== OPTIONAL: SSO (Single Sign-On) =====
# SSO is configured via the Admin UI (Settings > SSO Configuration), not via
# environment variables. Supported providers: Microsoft Entra ID (Azure AD).
# See docs/CONFIGURATION.md for details.

# ===== ADVANCED =====
# These defaults work for most deployments. Change only if needed.

# Rate limiting (default: enabled, 100 requests/60s global, 5 auth attempts/15s)
# RATE_LIMITING_ENABLED=true

# CORS allowed origins (default: http://localhost:3000)
# Set to your domain in production, e.g., https://knowz.example.com
# ALLOWED_ORIGIN=http://localhost:3000

# Swagger UI (default: enabled — disable in production if desired)
# ENABLE_SWAGGER=true
