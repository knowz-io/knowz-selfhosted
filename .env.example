# ===========================================================================
# Knowz Self-Hosted — Environment Configuration
# ===========================================================================
# Copy this file to .env and configure ONE AI mode below.
# .env is gitignored and will not be committed.
#
# AI MODES (pick ONE):
#   Mode 1: No AI (default)          — CRUD, auth, file uploads. No search/Q&A.
#   Mode 2: Knowz Platform (easiest) — Just paste your Knowz API key. All AI works.
#   Mode 3: Direct Azure (advanced)  — Your own Azure OpenAI + AI Search resources.
#
# QUICK START (recommended — get AI with one key):
#   cp .env.example .env
#   # Uncomment the "KNOWZ PLATFORM" section below, paste your API key
#   docker compose up --build
# ===========================================================================

# --- Core Settings (always active) -----------------------------------------

# SQL Server SA password (min 8 chars, must include uppercase, lowercase, number/symbol)
SA_PASSWORD=Knowz_Dev_P@ssw0rd!

# JWT secret for authentication tokens (CHANGE IN PRODUCTION — minimum 32 characters)
JWT_SECRET=change-this-to-a-random-64-char-string-in-production-please!!

# SuperAdmin credentials (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# MCP service-to-service key (must match on both API and MCP containers)
MCP_SERVICE_KEY=knowz-mcp-dev-service-key

# ===========================================================================
# MODE 2: Knowz Platform (RECOMMENDED — easiest, one API key)
# ===========================================================================
# All AI features powered by your Knowz account. Just paste your API key.
# Get your key at https://knowz.io → Settings → API Keys.
# No Azure subscription needed. Search uses local embeddings.
# Uncomment ALL three lines below and paste your API key.
# ---------------------------------------------------------------------------
# KNOWZ_PLATFORM_ENABLED=true
# KNOWZ_PLATFORM_URL=https://api.knowz.io
# KNOWZ_PLATFORM_APIKEY=your-platform-api-key

# ===========================================================================
# MODE 3: Direct Azure (advanced — bring your own Azure resources)
# ===========================================================================
# Full-featured: vector search, embeddings, AI summarization, Q&A.
# Requires your own Azure OpenAI and Azure AI Search resources.
# Uncomment ALL lines below and fill in your endpoint + key values.
# ---------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
# AZURE_OPENAI_APIKEY=your-azure-openai-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING=text-embedding-3-small
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_APIKEY=your-azure-search-admin-key
# AZURE_SEARCH_INDEX=knowz-selfhosted

# --- Optional: Azure AI Vision (image/diagram analysis — caption, tags, objects, OCR)
# AZURE_AI_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com/
# AZURE_AI_VISION_APIKEY=your-azure-vision-key

# --- Optional: Azure Document Intelligence (advanced PDF/Office extraction with layout)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_APIKEY=your-docintel-key

# ===========================================================================
# OPTIONAL: MCP Server
# ===========================================================================
# The MCP (Model Context Protocol) server enables AI tools (Claude, etc.) to
# interact with your knowledge base. It proxies requests to the API.
# These defaults work out of the box — change only if needed.
# ---------------------------------------------------------------------------
# MCP_PORT=3001
# MCP_BACKEND_MODE=selfhosted
# MCP_VALIDATE_API_KEY=true
# MCP_API_URL=http://api:8080
# MCP_API_KEY_VALIDATION_ENDPOINT=/api/vaults

# ===========================================================================
# OPTIONAL: Storage
# ===========================================================================
# Default: local filesystem (files stored in Docker volume).
# Uncomment to use Azure Blob Storage instead.
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=AzureBlobStorage
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;...
# AZURE_STORAGE_CONTAINER=selfhosted-files

# ===========================================================================
# OPTIONAL: SSO (Single Sign-On)
# ===========================================================================
# SSO is configured via the Admin UI (Settings > SSO Configuration), not via
# environment variables. Supported providers: Microsoft Entra ID (Azure AD).

# ===========================================================================
# ADVANCED (defaults work for most deployments)
# ===========================================================================
# RATE_LIMITING_ENABLED=true
# ALLOWED_ORIGIN=http://localhost:3000
# ENABLE_SWAGGER=true
