# =============================================================================
# Knowz Self-Hosted — Standard Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in required values.
# Sensitive values (passwords, keys) should be passed via CLI or env vars:
#   terraform apply -var sql_admin_password='<secure>'
#   export TF_VAR_sql_admin_password='<secure>'
# =============================================================================

# --- General ---
prefix              = "sh-test"
location            = "eastus2"
resource_group_name = "rg-knowz-selfhosted"

# --- SQL ---
# sql_admin_password = ""  # REQUIRED — pass via CLI or TF_VAR_sql_admin_password
# allow_all_ips      = false

# --- Azure OpenAI ---
deploy_openai           = true
chat_deployment_name    = "gpt-5.2-chat"
embedding_deployment_name = "text-embedding-3-small"
embedding_model_name    = "text-embedding-3-small"
# If using external OpenAI (deploy_openai = false):
# external_openai_endpoint = "https://your-openai.openai.azure.com/"
# external_openai_key      = ""  # pass via CLI or TF_VAR_external_openai_key

# --- Document Intelligence ---
deploy_document_intelligence = true
# If using external Document Intelligence (deploy_document_intelligence = false):
# external_doc_intel_endpoint = "https://your-docintel.cognitiveservices.azure.com/"
# external_doc_intel_key      = ""  # pass via CLI or TF_VAR_external_doc_intel_key

# --- AI Search ---
search_sku      = "basic"
# search_location = ""  # Override if SKU unavailable in primary location

# --- Key Vault ---
deploy_key_vault = true

# --- Monitoring ---
deploy_monitoring = true

# --- Storage ---
# storage_allow_shared_key_access = true

# --- Container Apps (opt-in) ---
deploy_container_apps = false
# image_tag             = "latest"
# registry_server       = "ghcr.io"
# registry_username     = ""       # Only for private registries
# registry_password     = ""       # pass via CLI or TF_VAR_registry_password
# api_key               = ""       # Auto-generated if empty
# jwt_secret            = ""       # Auto-generated if empty
# admin_password        = "changeme"

# --- Tags ---
# tags = {
#   team = "platform"
#   cost_center = "engineering"
# }
